# Resend email sending. Keep RESEND_API_KEY server-side only.
RESEND_API_KEY=re_your_resend_api_key_here

# Use onboarding@resend.dev for testing until your sending domain is verified.
# After domain verification, use a real sender such as Bonsai Florida <hello@yourdomain.com>.
RESEND_FROM_EMAIL=Bonsai Florida <onboarding@resend.dev>
