# Google Calendar Appointment Schedule booking page.
# Replace this with the real appointment schedule URL from Google Calendar.
NEXT_PUBLIC_GOOGLE_BOOKING_URL=https://calendar.google.com/calendar/appointments/schedules/AcZssZ2rQtgIgRIvKdusIMMARHlSxDTqPkyVpjcaRj8FYeULUNtJkIU8sMhWsD9ccA1iymKsd4wjE3Xw?gv=true

# Public production site URL used to convert local email images into hosted URLs.
NEXT_PUBLIC_SITE_URL=https://bonsai-florida.vercel.app

# Supabase. Only NEXT_PUBLIC_* values are browser-visible; keep service role server-side.
NEXT_PUBLIC_SUPABASE_URL=https://kezvvfocbpbyykgeohsw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Staff admin login. Keep these server-side only.
ADMIN_USERNAME=your_staff_username
ADMIN_PASSWORD=your_staff_password

# Resend email sending. Keep RESEND_API_KEY server-side only.
RESEND_API_KEY=re_your_resend_api_key_here

# Use onboarding@resend.dev for testing until your sending domain is verified.
# After domain verification, use a real sender such as Bonsai Florida <hello@yourdomain.com>.
RESEND_FROM_EMAIL=Bonsai Florida <onboarding@resend.dev>

# Disabled by default so /api/test-email cannot be abused publicly.
EMAIL_TEST_ENABLED=false

# n8n webhook for single-tree manual autopost (existing).
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bonsai-autopost
N8N_WEBHOOK_SECRET=your_webhook_secret_here

# n8n webhook for the daily cron autopost (receives full formatted payload).
# Create a new n8n workflow triggered by this webhook URL.
N8N_CRON_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bonsai-cron-autopost

# Secret Vercel sends automatically when calling cron routes.
# Generate any random string: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
